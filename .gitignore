# .gitignore for Autonomous Ticket Triage

# Virtual environment
venv/
env/
.venv/

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.egg-info/
dist/
build/

# Data files (generated, can be large)
data/raw/
data/processed/
data/chroma_db/
data/evaluation_results.json

# Test results (generated)
tests/dense_only_retrival/results/
tests/sparse_only_retrival/results/
tests/hybrid_retrival/results/

# Environment variables (contains secrets)
.env

# Logs
logs/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS files
Thumbs.db
.DS_Store
